# Frontend build-time config (Vite). Copy to .env.local for local overrides.
# Leave BOTH unset for local dev — the Vite dev server proxies /api and /ws to :8000.

# Production: the Render backend origin.
# VITE_API_BASE=https://railmind-backend.onrender.com
# VITE_WS_URL=wss://railmind-backend.onrender.com/ws
