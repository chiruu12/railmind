{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "includeFiles": "api/_src/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/health", "destination": "/api/index.py" }
  ]
}
